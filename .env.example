DATABASE_URL=               # Supabase Postgres (pooled)
DIRECT_URL=                  # Supabase Postgres (direct, pour Prisma migrate)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # worker + signed URLs
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # pk_test_… — active le paiement embarqué dans la galerie
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=        # ex: whatsapp:+14155238886 (sandbox en dev)
TWILIO_SMS_FROM=             # numéro Twilio SMS (E.164, ex: +14155551234) — sans préfixe whatsapp:
RESEND_API_KEY=              # clé API Resend pour l'envoi de l'email brandé
RESEND_FROM_EMAIL=           # ex: "Vol Passion Annecy <hello@souvenir.app>" — domaine vérifié sur Resend
NEXT_PUBLIC_APP_URL=         # https://app.souvenir... (ou http://localhost:3000)
NEXT_PUBLIC_CALENDLY_URL=    # optionnel — lien Calendly pour la section RDV de la landing ; si vide, le bouton retombe sur mailto:hello@souvenir.app
