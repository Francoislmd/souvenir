generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Operator {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoUrl         String?
  brandColor      String   @default("#FF5A1F") // one of the 7 Linktrip swatches; drives boutique --op only

  stripeAccountId String?
  stripeOnboarded Boolean  @default(false)

  pricePhotoCents Int      @default(800)
  pricePackCents  Int      @default(2200)
  priceAllCents   Int      @default(3900)
  packSize        Int      @default(3)
  freeCount       Int      @default(2)
  feePercent      Int      @default(20)

  // { resendUnopened, reducedPriceOffer, reviewRequest, referral } — referral always false, "bientôt"
  automations     Json     @default("{\"resendUnopened\":true,\"reducedPriceOffer\":true,\"reviewRequest\":true,\"referral\":false}")

  googleReviewUrl String?
  whatsappNumber  String?
  activities      String[] @default([]) // ids @souvenir/web:lib/onboarding/activities.ts — choisis à l'inscription, modifiables en réglages

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  sorties Sortie[]
  events  Event[]
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  role       Role     @default(MONITEUR) // kept for future use; no longer gates the 3-tab nav
  operatorId String
  createdAt  DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
}

enum Role {
  ADMIN
  MONITEUR
}

model Sortie {
  id         String       @id @default(cuid())
  operatorId String
  activity   String
  place      String?
  startsAt   DateTime
  seats      Int          @default(8)
  guide      String?
  status     SortieStatus @default(UPCOMING) // UPCOMING -> SORTED -> SENT; "today" is computed from startsAt, never stored
  createdAt  DateTime     @default(now())

  operator     Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  participants Participant[]
  photos       Photo[]

  @@index([operatorId])
  @@index([operatorId, startsAt])
}

enum SortieStatus {
  UPCOMING
  SORTED
  SENT
}

model Participant {
  id      String  @id @default(cuid())
  sortieId String
  name    String
  contact String  // email OR phone, mandatory — cannot create without one
  channel Channel // deriveChannel(contact)
  token   String  @unique // /g/{token} — the only secret, must be non-guessable

  consentAt DateTime  @default(now())
  deleteAt  DateTime  // consentAt + 90d, RGPD purge cron target
  deletedAt DateTime?

  sentAt                DateTime?
  openedAt               DateTime?
  remindedAt             DateTime? // +2h resend idempotency
  reducedOfferSentAt     DateTime? // +24h offer idempotency
  reducedOfferExpiresAt  DateTime? // offer valid 48h, read by quote()
  reviewRequestSentAt    DateTime? // post-purchase idempotency

  createdAt DateTime @default(now())

  sortie Sortie   @relation(fields: [sortieId], references: [id], onDelete: Cascade)
  order  Order?
  photos Photo[]  @relation("PhotoOwner")

  @@index([sortieId])
  @@index([deleteAt])
}

enum Channel {
  EMAIL
  WHATSAPP
}

model Photo {
  id           String      @id @default(cuid())
  sortieId     String
  ownerId      String?     // null = common photo, visible to every participant of the sortie
  originalKey  String
  previewKey   String?
  thumbKey     String?
  takenAt      DateTime?   // unpopulated in v1, reserved for future EXIF clustering
  isVideo      Boolean     @default(false)
  isFreeSample Boolean     @default(false) // computed at assign time, see lib/assign.ts
  status       PhotoStatus @default(UPLOADED)
  createdAt    DateTime    @default(now())

  sortie Sortie          @relation(fields: [sortieId], references: [id], onDelete: Cascade)
  owner  Participant?    @relation("PhotoOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  jobs   ProcessingJob[]

  @@index([sortieId])
  @@index([ownerId])
}

enum PhotoStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

model Order {
  id            String    @id @default(cuid())
  participantId String    @unique
  photoIds      String[]
  amountCents   Int
  feeCents      Int
  stripePi      String?   @unique
  status        String    @default("pending") // pending | succeeded | failed
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

model ProcessingJob {
  id        String    @id @default(cuid())
  photoId   String
  kind      String    // "preview" only in v1
  status    String    @default("pending")
  attempts  Int       @default(0)
  lockedAt  DateTime?
  createdAt DateTime  @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([photoId])
}

model Event {
  id            String   @id @default(cuid())
  operatorId    String
  participantId String?
  name          String
  meta          Json?
  createdAt     DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([participantId])
  @@index([name])
}

// Limitation de débit sur la connexion et la demande de réinitialisation —
// une ligne par tentative, comptée sur une fenêtre glissante. Pas de Redis :
// même logique "table Postgres" que ProcessingJob (cf. CLAUDE.md §2.3).
model AuthAttempt {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}
